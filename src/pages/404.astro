---
import { defaultLocale, isLocale, type Locale, withLocalePath } from '@i18n/config';

const maybeLocale = Astro.url.pathname.split('/').filter(Boolean)[0];
const locale: Locale = isLocale(maybeLocale) ? maybeLocale : defaultLocale;

const copy: Record<
  Locale,
  { title: string; subtitle: string; description: string; cta: string; alt: string }
> = {
  es: {
    title: 'Error 404',
    subtitle: 'Esta página no existe',
    description:
      'Benny ya la buscó por toda la galaxia. Es posible que el enlace haya cambiado o que la página se haya movido.',
    cta: 'Ir al inicio',
    alt: 'Benny astronauta',
  },
  en: {
    title: 'Error 404',
    subtitle: 'This page does not exist',
    description:
      'Benny already searched the whole galaxy. The link may have changed, or the page may have moved.',
    cta: 'Go home',
    alt: 'Benny astronaut',
  },
  pt: {
    title: 'Erro 404',
    subtitle: 'Esta página não existe',
    description:
      'O Benny já procurou por toda a galáxia. É possível que o link tenha mudado ou que a página tenha sido movida.',
    cta: 'Ir para o início',
    alt: 'Benny astronauta',
  },
};

const homeHref = withLocalePath(locale, '/');
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{copy[locale].title} | gndx.dev</title>
  </head>
  <body>
    <section class="not-found">
      <div class="panel">
        <h1 class="title">{copy[locale].title}</h1>

        <div class="benny-wrap">
          <img
            src="https://s3.us-east-1.amazonaws.com/gndx.dev/gndx_benny.png"
            alt={copy[locale].alt}
            class="benny-image"
            loading="eager"
            decoding="async"
          />
        </div>

        <h2 class="title">{copy[locale].subtitle}</h2>
        <p>{copy[locale].description}</p>

        <div class="actions">
          <a class="btn btn-primary" href={homeHref}>{copy[locale].cta}</a>
        </div>
      </div>
    </section>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    padding: 0;
    background: #ffffff;
  }

  .not-found {
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: 0.5rem;
    background: #ffffff;
  }

  .panel {
    width: min(760px, 100%);
    text-align: center;
    background: #ffffff;
    border-radius: 0;
    border: 0;
    box-shadow: none;
    padding: 1.2rem 0.8rem 1.8rem;
  }

  .title {
    margin: 0;
    font-size: clamp(1.45rem, 2.8vw, 2.3rem);
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: #000000;
  }

  .benny-wrap {
    margin: 0.4rem auto 0.7rem;
    display: grid;
    place-items: center;
  }

  .benny-image {
    width: min(250px, 48vw);
    height: auto;
    filter: none;
    user-select: none;
    -webkit-user-drag: none;
    animation: float-benny 3.8s ease-in-out infinite;
  }

  p {
    margin: 0.75rem auto 0;
    max-width: 58ch;
    color: #000000;
    line-height: 1.6;
  }

  .actions {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.72rem 1.15rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 180ms ease, background-color 180ms ease;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    color: #ffffff;
    background: #111827;
  }

  .btn-primary:hover {
    background: #000000;
  }

  @keyframes float-benny {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  @media (max-width: 560px) {
    .panel {
      padding: 1.1rem 0.4rem 1.4rem;
    }

    p {
      font-size: 0.95rem;
      line-height: 1.5;
    }

    .btn {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation: none !important;
      transition: none !important;
    }
  }
</style>

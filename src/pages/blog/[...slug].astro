---
import { render, type CollectionEntry, getCollection } from "astro:content";

import BlogPost from "@layouts/BlogPost.astro";
import Code from "@components/mdx/Code.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blogEs");
  return posts.map((post) => ({
    params: { slug: post.slug || post.id.replace(/\.(md|mdx)$/i, '') },
  }));
}
type Props = CollectionEntry<"blogEs">;

const { slug } = Astro.params;
const posts = await getCollection("blogEs");
const post = posts.find((item) => (item.slug || item.id.replace(/\.(md|mdx)$/i, '')) === slug) as Props | undefined;
if (!post) {
  return Astro.redirect('/blog/');
}
const { Content } = await render(post);
---

<BlogPost {...post.data}>
  <Content components={{ pre: Code }} />
</BlogPost>

---
import Base from "@layouts/Base.astro";
import TaxonomyPosts from "@components/TaxonomyPosts.astro";

import { getTaxonomy } from "@utils/getAllTags";
import { getSinglePage } from "@utils/getAllTags";
import { taxonomyFilter } from "@utils/getAllTags";
import { deslugify } from "@utils/slug";

export async function getStaticPaths() {
  const tags = await getTaxonomy("blogEs", "tags");

  return tags.map((tag) => {
    return {
      params: { tag: tag.slug },
    };
  });
}

const { tag } = Astro.params;

const posts = await getSinglePage("blogEs");
const filterByTags = taxonomyFilter(posts, "tags", tag);
---

<Base>
  <TaxonomyPosts
    posts={filterByTags}
    term={deslugify(tag as string)}
    prefixLabel="Tag"
    subtitle="Ver posts con el tag"
    locale="es"
  />
</Base>

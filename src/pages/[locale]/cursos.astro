---
import Base from '@layouts/Base.astro';
import Page from '@layouts/Page.astro';
import { prefixedLocales, isLocale } from '@i18n/config';

export async function getStaticPaths() {
  return prefixedLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isLocale(locale)) return Astro.redirect('/');

const content = {
  es: { title: 'Cursos', body: 'Cursos y recursos para aprender JavaScript y tecnologias web.' },
  en: { title: 'Courses', body: 'Courses and resources to learn JavaScript and web technologies.' },
  pt: { title: 'Cursos', body: 'Cursos e recursos para aprender JavaScript e tecnologias web.' }
}[locale];
---

<Base locale={locale} meta_title={content.title}>
  <Page title={content.title}>
    <p>{content.body}</p>
    <a href='https://platzi.com/conoceme/gndx' target='_blank' class='text-2xl font-bold mt-8'>Platzi</a>
  </Page>
</Base>

---
import Base from '@layouts/Base.astro';
import Page from '@layouts/Page.astro';
import { locales, isLocale } from '@i18n/config';
import { getUi } from '@i18n/ui';

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isLocale(locale)) return Astro.redirect('/es/');
const copy = getUi(locale);

const content = {
  es: { title: 'Mentoria', body: 'Sesiones 1:1 para acelerar tu crecimiento profesional en tecnologia.' },
  en: { title: 'Mentoring', body: '1:1 sessions to accelerate your professional growth in technology.' },
  pt: { title: 'Mentoria', body: 'Sessoes 1:1 para acelerar seu crescimento profissional em tecnologia.' }
}[locale];
---

<Base locale={locale} meta_title={content.title}>
  <Page title={content.title}>
    <p>{content.body}</p>
    <a
      href='https://mentor.gndx.dev/'
      class='inline-block rounded border border-indigo-600 px-12 mt-8 py-3 text-md font-medium text-indigo-600 hover:bg-indigo-600 hover:text-white focus:outline-none focus:ring active:bg-indigo-500'
    >
      {copy.labels.scheduleSession}
    </a>
  </Page>
</Base>

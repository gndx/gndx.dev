---
import Base from '@layouts/Base.astro';
import TaxonomyPosts from '@components/TaxonomyPosts.astro';
import { getPostsByLocale, filterByTaxonomy } from '@utils/i18nContent';
import { prefixedLocales, isLocale } from '@i18n/config';
import { deslugify } from '@utils/slug';
import { getUi } from '@i18n/ui';

export async function getStaticPaths() {
  const paths = [];
  for (const locale of prefixedLocales) {
    const posts = await getPostsByLocale(locale);
    const categories = new Set(posts.flatMap((post) => post.data.categories.map((item) => item.toLowerCase())));
    for (const category of categories) {
      paths.push({ params: { locale, category: category.replaceAll(' ', '-') } });
    }
  }
  return paths;
}

const { locale, category } = Astro.params;
if (!isLocale(locale)) return Astro.redirect('/');

const posts = await getPostsByLocale(locale);
const filterByCategory = filterByTaxonomy(posts, 'categories', category as string);
const copy = getUi(locale);
---

<Base locale={locale}>
  <TaxonomyPosts
    posts={filterByCategory}
    term={deslugify(category as string)}
    prefixLabel={copy.labels.categoryPrefix}
    subtitle={copy.labels.postsWithCategory}
    locale={locale}
  />
</Base>

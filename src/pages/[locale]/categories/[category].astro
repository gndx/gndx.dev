---
import Base from '@layouts/Base.astro';
import CategoryIcon from '@icons/CategoryIcon.astro';
import { getPostsByLocale, filterByTaxonomy } from '@utils/i18nContent';
import { locales, isLocale, withLocalePath } from '@i18n/config';
import { deslugify } from '@utils/slug';
import { getUi } from '@i18n/ui';

export async function getStaticPaths() {
  const paths = [];
  for (const locale of locales) {
    const posts = await getPostsByLocale(locale);
    const categories = new Set(posts.flatMap((post) => post.data.categories.map((item) => item.toLowerCase())));
    for (const category of categories) {
      paths.push({ params: { locale, category: category.replaceAll(' ', '-') } });
    }
  }
  return paths;
}

const { locale, category } = Astro.params;
if (!isLocale(locale)) return Astro.redirect('/es/');

const posts = await getPostsByLocale(locale);
const filterByCategory = filterByTaxonomy(posts, 'categories', category as string);
const copy = getUi(locale);
---

<Base locale={locale}>
  <h1 class='text-2xl md:text-3xl font-bold mb-8 capitalize'>
    {copy.labels.categoryPrefix}: {deslugify(category as string)}
  </h1>
  <ul class='space-y-4 text-left ml-4 text-gray-500 dark:text-gray-400'>
    {
      filterByCategory.map((post) => (
        <li class='flex items-center space-x-1'>
          <CategoryIcon />
          <a href={withLocalePath(locale, `/blog/${post.slug}`)} class='text-gray-500 hover:text-gray-800'>
            {post.data.title}
          </a>
        </li>
      ))
    }
  </ul>
</Base>

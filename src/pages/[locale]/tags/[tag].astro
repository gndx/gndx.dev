---
import Base from '@layouts/Base.astro';
import TaxonomyPosts from '@components/TaxonomyPosts.astro';
import { getPostsByLocale, filterByTaxonomy } from '@utils/i18nContent';
import { prefixedLocales, isLocale } from '@i18n/config';
import { deslugify } from '@utils/slug';
import { getUi } from '@i18n/ui';

export async function getStaticPaths() {
  const paths = [];
  for (const locale of prefixedLocales) {
    const posts = await getPostsByLocale(locale);
    const tags = new Set(posts.flatMap((post) => post.data.tags.map((item) => item.toLowerCase())));
    for (const tag of tags) {
      paths.push({ params: { locale, tag: tag.replaceAll(' ', '-') } });
    }
  }
  return paths;
}

const { locale, tag } = Astro.params;
if (!isLocale(locale)) return Astro.redirect('/');

const posts = await getPostsByLocale(locale);
const filterByTags = filterByTaxonomy(posts, 'tags', tag as string);
const copy = getUi(locale);
---

<Base locale={locale}>
  <TaxonomyPosts
    posts={filterByTags}
    term={deslugify(tag as string)}
    prefixLabel={copy.labels.tagPrefix}
    subtitle={copy.labels.postsWithTag}
    locale={locale}
  />
</Base>

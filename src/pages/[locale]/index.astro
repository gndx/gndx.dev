---
import HomePagination from '@components/HomePagination.astro';
import Base from '@layouts/Base.astro';
import Posts from '@layouts/Posts.astro';
import { locales, type Locale, isLocale } from '@i18n/config';
import { getPostsByLocale } from '@utils/i18nContent';

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isLocale(locale)) return Astro.redirect('/es/');

const posts = await getPostsByLocale(locale);
---

<Base locale={locale}>
  <Posts posts={posts} locale={locale as Locale} />
  <HomePagination locale={locale as Locale} />
</Base>

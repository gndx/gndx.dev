---
import { type Locale, withLocalePath } from '@i18n/config';
import { getUi } from '@i18n/ui';

interface Props {
  locale?: Locale;
}

const { locale = 'es' } = Astro.props;
const copy = getUi(locale);
---

<div class='m-auto mt-10 flex justify-end'>
  <a class='nd-view-all' href={withLocalePath(locale, '/blog')}>
    <span>{copy.labels.viewAll}</span>
    <span class='nd-arrow' aria-hidden='true'>→</span>
  </a>
</div>

<style>
  .nd-view-all {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--nd-text-primary);
    border: 1px solid var(--nd-border-visible);
    padding: 10px 20px 10px 24px;
    border-radius: 999px;
    transition: color 200ms ease, border-color 200ms ease;
  }

  .nd-view-all:hover {
    color: var(--nd-text-display);
    border-color: var(--nd-text-disabled);
  }

  .nd-arrow {
    color: var(--nd-text-secondary);
    transition: transform 200ms ease;
    display: inline-block;
  }

  .nd-view-all:hover .nd-arrow {
    transform: translateX(4px);
    color: var(--nd-text-display);
  }
</style>

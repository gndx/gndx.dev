---
import { locales, type Locale, withLocalePath } from '@i18n/config';

interface Props {
  locale: Locale;
  variant?: 'dropdown' | 'list';
  className?: string;
}

const { locale, variant = 'dropdown', className = '' } = Astro.props as Props;
const labels: Record<Locale, string> = { es: 'Español', en: 'English', pt: 'Português' };
const currentPath = Astro.url.pathname;
---

{
  variant === 'list' ? (
    <div class={`${className}`.trim()}>
      <p class='nd-lang-label'>Idioma</p>
      <ul class='pb-2' aria-label='Language options'>
        {
          locales.map((lang) => (
            <li>
              <a
                href={withLocalePath(lang, currentPath)}
                data-lang={lang}
                class={`nd-lang-list-item ${lang === locale ? 'nd-lang-active' : ''}`}
              >
                {labels[lang]}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  ) : (
    <div class={`ml-4 relative ${className}`.trim()}>
      <details class='relative group language-switcher'>
        <summary
          class='nd-lang-btn flex h-8 w-8 cursor-pointer list-none items-center justify-center'
          aria-label='Open language menu'
        >
          <svg
            aria-hidden='true'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='1.5'
            stroke-linecap='round'
            stroke-linejoin='round'
            class='h-[16px] w-[16px]'
          >
            <path d='m5 8 6 6'></path>
            <path d='m4 14 6-6 2-3'></path>
            <path d='M2 5h12'></path>
            <path d='M7 2h1'></path>
            <path d='m22 22-5-10-5 10'></path>
            <path d='M14 18h6'></path>
          </svg>
        </summary>
        <ul
          class='language-menu absolute right-0 z-20 mt-2 w-36 overflow-hidden nd-lang-dropdown'
          aria-label='Language options'
        >
          {
            locales.map((lang) => (
              <li>
                <a
                  href={withLocalePath(lang, currentPath)}
                  data-lang={lang}
                  class={`nd-lang-dropdown-item ${lang === locale ? 'nd-lang-active' : ''}`}
                >
                  {labels[lang]}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
    </div>
  )
}

<style>
  .language-switcher > summary::-webkit-details-marker {
    display: none;
  }

  .nd-lang-label {
    padding: 12px 16px 4px;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--nd-text-disabled);
  }

  .nd-lang-list-item {
    display: block;
    padding: 8px 16px;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--nd-text-secondary);
    transition: color 200ms ease;
  }

  .nd-lang-list-item:hover,
  .nd-lang-list-item.nd-lang-active {
    color: var(--nd-text-display);
  }

  .nd-lang-btn {
    border: 1px solid var(--nd-border-visible);
    border-radius: 6px;
    color: var(--nd-text-secondary);
    transition: color 200ms ease, border-color 200ms ease;
  }

  .nd-lang-btn:hover {
    color: var(--nd-text-display);
    border-color: var(--nd-text-disabled);
  }

  .nd-lang-dropdown {
    background: var(--nd-surface-raised);
    border: 1px solid var(--nd-border-visible);
    border-radius: 8px;
    opacity: 0;
    transform: translateY(-6px) scale(0.97);
    transform-origin: top right;
    pointer-events: none;
    transition: opacity 160ms ease, transform 180ms ease;
  }

  .language-switcher[open] .nd-lang-dropdown {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .nd-lang-dropdown-item {
    display: block;
    padding: 10px 14px;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--nd-text-secondary);
    transition: color 200ms ease;
  }

  .nd-lang-dropdown-item:hover,
  .nd-lang-dropdown-item.nd-lang-active {
    color: var(--nd-text-display);
  }

  .language-switcher[open] > summary {
    color: var(--nd-text-display);
    border-color: var(--nd-text-disabled);
  }
</style>

<script>
  document.querySelectorAll('[data-lang]').forEach((item) => {
    item.addEventListener('click', () => {
      const lang = item.getAttribute('data-lang');
      if (!lang) return;
      document.cookie = `lang=${lang}; Max-Age=31536000; Path=/; SameSite=Lax`;
    });
  });
</script>

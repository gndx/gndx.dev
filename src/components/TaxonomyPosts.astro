---
import FormattedDate from '@components/FormattedDate.astro';
import { type Locale, withLocalePath } from '@i18n/config';
import { heroPatterns } from '@utils/heroPatterns';

interface PostType {
  id: string;
  slug?: string;
  data: {
    title: string;
    description: string;
    pubDate: Date;
  };
}

interface Props {
  posts: PostType[];
  term: string;
  prefixLabel: string;
  subtitle: string;
  locale?: Locale;
}

const { posts, term, prefixLabel, subtitle, locale = 'es' } = Astro.props as Props;

const dateLocaleMap: Record<Locale, string> = {
  es: 'es-ES',
  en: 'en-US',
  pt: 'pt-BR'
};

const ctaByLocale: Record<Locale, string> = {
  es: 'Abrir post',
  en: 'Open post',
  pt: 'Abrir post'
};

const postWordByLocale: Record<Locale, { singular: string; plural: string; empty: string }> = {
  es: { singular: 'post', plural: 'posts', empty: 'No hay posts para este filtro todavia.' },
  en: { singular: 'post', plural: 'posts', empty: 'There are no posts for this filter yet.' },
  pt: { singular: 'post', plural: 'posts', empty: 'Ainda nao ha posts para este filtro.' }
};

const postLabel = posts.length === 1 ? postWordByLocale[locale].singular : postWordByLocale[locale].plural;
const getPostSlug = (post: PostType) => post.slug || post.id?.replace(/\.(md|mdx)$/i, '') || '';

const patternForegroundPalette = ['#d71921', '#5b9bf6', '#4a9e5c', '#d4a843', '#8b5cf6', '#22d3ee', '#f97316'];
const surfacePalette = ['#0d0a0a', '#090d12', '#090d0a', '#0d0c08', '#0b090f', '#080d0e', '#0e0b07'];

const hashString = (value: string) => {
  let hash = 0;
  for (let index = 0; index < value.length; index += 1) {
    hash = (hash << 5) - hash + value.charCodeAt(index);
    hash |= 0;
  }
  return Math.abs(hash);
};

const withOpacity = (hex: string, opacity: number) => {
  const normalized = hex.replace('#', '');
  const withFullLength =
    normalized.length === 3
      ? normalized
          .split('')
          .map((part) => `${part}${part}`)
          .join('')
      : normalized;
  const r = Number.parseInt(withFullLength.slice(0, 2), 16);
  const g = Number.parseInt(withFullLength.slice(2, 4), 16);
  const b = Number.parseInt(withFullLength.slice(4, 6), 16);
  return `rgba(${r}, ${g}, ${b}, ${opacity})`;
};

const toPatternDataUri = (svg: string, color: string) => {
  const coloredSvg = svg.replace(/#000/g, color).replace(/\n/g, '').replace(/\s{2,}/g, ' ');
  return `url("data:image/svg+xml,${encodeURIComponent(coloredSvg)}")`;
};

const getPatternStyle = (seedValue: string) => {
  const seed = hashString(seedValue);
  const pattern = heroPatterns[seed % heroPatterns.length];
  const patternColorBase = patternForegroundPalette[Math.floor(seed / 3) % patternForegroundPalette.length];
  const surfaceColor = surfacePalette[Math.floor(seed / 7) % surfacePalette.length];
  const patternColor = withOpacity(patternColorBase, 0.22);

  return {
    surfaceColor,
    patternImage: toPatternDataUri(pattern.svg, patternColor)
  };
};

const { surfaceColor, patternImage } = getPatternStyle(`${prefixLabel}-${term}-${locale}`);
---

<section class='mb-8'>
  <div class='tx-hero relative overflow-hidden' style={`background-color:${surfaceColor};`}>
    <div class='taxonomy-pattern-layer absolute inset-0' style={`background-image:${patternImage};`} />
    <div class='tx-overlay absolute inset-0' style='background: linear-gradient(160deg, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.2) 100%);' />
    <div class='relative z-10 p-6 md:p-8'>
      <span class='tx-label'>{prefixLabel}</span>
      <h1 class='tx-title'>{term}</h1>
      <p class='tx-subtitle'>{subtitle} · {posts.length} {postLabel}</p>
    </div>
  </div>
</section>

{
  posts.length > 0 ? (
    <div class='grid grid-cols-1 gap-4 md:grid-cols-2'>
      {
        posts.map((post) => (
          <article class='tx-card group relative flex h-full flex-col'>
            <a href={withLocalePath(locale, `/blog/${getPostSlug(post)}`)} class='absolute inset-0 z-10' aria-label={post.data.title}></a>
            <div class='tx-date'>
              <FormattedDate date={post.data.pubDate} locale={dateLocaleMap[locale]} />
            </div>
            <h2 class='tx-post-title'>{post.data.title}</h2>
            <p class='tx-desc line-clamp-3'>{post.data.description}</p>
            <span class='tx-cta mt-auto'>
              {ctaByLocale[locale]}
              <span class='ml-1' aria-hidden='true'>→</span>
            </span>
          </article>
        ))
      }
    </div>
  ) : (
    <div class='tx-empty'>
      {postWordByLocale[locale].empty}
    </div>
  )
}

<style>
  .tx-hero {
    border-radius: 12px;
    border: 1px solid var(--nd-border);
    overflow: hidden;
  }

  .taxonomy-pattern-layer {
    background-repeat: repeat;
    animation: taxonomyPatternShift 68s linear infinite;
  }

  @keyframes taxonomyPatternShift {
    from { background-position: 0 0; }
    to   { background-position: 42px 0; }
  }

  .tx-label {
    display: inline-flex;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--nd-text-secondary);
    border: 1px solid var(--nd-border-visible);
    padding: 4px 10px;
    border-radius: 999px;
  }

  .tx-title {
    margin-top: 12px;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.15;
    text-transform: uppercase;
    color: var(--nd-text-display);
  }

  .tx-subtitle {
    margin-top: 8px;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--nd-text-secondary);
  }

  .tx-card {
    background: var(--nd-surface);
    border: 1px solid var(--nd-border);
    border-radius: 12px;
    padding: 20px;
    transition: border-color 250ms ease;
  }

  .tx-card:hover {
    border-color: var(--nd-border-visible);
  }

  .tx-date {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--nd-text-disabled);
  }

  .tx-post-title {
    margin-top: 10px;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--nd-text-display);
    transition: color 200ms ease;
  }

  .tx-card:hover .tx-post-title {
    color: var(--nd-text-primary);
  }

  .tx-desc {
    margin-top: 8px;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--nd-text-secondary);
  }

  .tx-cta {
    display: inline-flex;
    align-items: center;
    margin-top: 16px;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--nd-text-disabled);
    transition: color 200ms ease;
  }

  .tx-card:hover .tx-cta {
    color: var(--nd-text-secondary);
  }

  .tx-empty {
    border: 1px solid var(--nd-border);
    border-radius: 12px;
    padding: 40px;
    text-align: center;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--nd-text-disabled);
  }

  /* Light mode: override dark tinted surfaces */
  :root[data-theme='light'] .tx-hero {
    background-color: var(--nd-surface-raised) !important;
  }

  :root[data-theme='light'] .tx-overlay {
    background: linear-gradient(160deg, rgba(0,0,0,0.08) 0%, rgba(0,0,0,0.02) 100%) !important;
  }

  :root[data-theme='light'] .tx-title {
    color: var(--nd-text-display);
  }

  @media (prefers-color-scheme: light) {
    :root:not([data-theme='dark']) .tx-hero {
      background-color: var(--nd-surface-raised) !important;
    }

    :root:not([data-theme='dark']) .tx-overlay {
      background: linear-gradient(160deg, rgba(0,0,0,0.08) 0%, rgba(0,0,0,0.02) 100%) !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .taxonomy-pattern-layer { animation: none; }
    .tx-card { transition: none; }
  }
</style>

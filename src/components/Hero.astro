---
import { Image } from 'astro:assets';
import config from '@config/config.json';
import social from '@config/social';

export interface SocialMedia {
  icon: string;
  url: string;
  svg: string;
}

interface Props {
  socialItems?: SocialMedia[];
}

const socialItems = social.networks;
const hashtags = (config.author.bio.match(/#[\p{L}\p{N}_-]+/gu) ?? []).filter(
  (tag) => tag.toLowerCase() !== '#withastro'
);
const bioMain = config.author.bio
  .replace(/#[\p{L}\p{N}_-]+/gu, '')
  .replace(/-\s*-/g, '-')
  .replace(/\s{2,}/g, ' ')
  .trim();
---

<section class='nd-hero'>
  <div class='mx-auto max-w-screen-lg px-4 sm:px-6 lg:px-8' style='padding-top: 32px; padding-bottom: 48px;'>
    <div class='flex items-start justify-between gap-8'>
      <div class='flex-1 min-w-0'>
        <h1 class='nd-hero-name'>{config.author.name}</h1>
        <p class='nd-hero-bio'>{bioMain}</p>
        {
          hashtags.length > 0 && (
            <p class='nd-hero-tags'>{hashtags.join(' ')}</p>
          )
        }
        <div class='nd-social-row'>
          {
            socialItems?.map((item) => (
              <a href={item.url} target='_blank' rel='noopener noreferrer' class='nd-social-icon'>
                <figure>
                  <Fragment set:html={item.svg} />
                </figure>
              </a>
            ))
          }
        </div>
      </div>

      <div class='flex-shrink-0'>
        <figure>
          <Image
            class='nd-avatar'
            width={512}
            height={512}
            src={config.author.avatar}
            alt={config.author.name}
            decoding='async'
            loading='lazy'
          />
        </figure>
      </div>
    </div>
  </div>
</section>

<style>
  .nd-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--nd-border);
  }

  /* Nothing dot-grid motif — fades at the bottom */
  .nd-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(circle, var(--nd-border-visible) 1px, transparent 1px);
    background-size: 24px 24px;
    mask-image: linear-gradient(to bottom, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0) 100%);
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0) 100%);
  }

  .nd-hero > * {
    position: relative;
    z-index: 1;
  }

  .nd-hero-name {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: clamp(2rem, 3.5vw + 0.5rem, 3rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--nd-text-display);
    margin: 0 0 8px 0;
    line-height: 1.1;
  }

  .nd-hero-bio {
    margin: 0 0 8px 0;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--nd-text-secondary);
    max-width: 75%;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .nd-hero-tags {
    margin: 0 0 24px 0;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--nd-warning);
    opacity: 0.75;
  }

  .nd-social-row {
    display: flex;
    gap: 12px;
    margin-top: 24px;
  }

  .nd-social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--nd-border-visible);
    border-radius: 8px;
    color: var(--nd-text-secondary);
    transition: color 200ms ease, border-color 200ms ease;
  }

  .nd-social-icon:hover {
    color: var(--nd-warning);
    border-color: var(--nd-warning);
  }

  .nd-social-icon :global(svg) {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .nd-avatar {
    width: 80px;
    height: 80px;
    border-radius: 8px;
    border: 1px solid var(--nd-border-visible);
  }

  @media (min-width: 640px) {
    .nd-avatar {
      width: 100px;
      height: 100px;
    }
  }
</style>

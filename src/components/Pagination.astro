---
import NextIcon from '@icons/NextIcon.astro';
import PrevIcon from '@icons/PrevIcon.astro';

const { length, currentPage, firstUrl, prevUrl, nextUrl } = Astro.props;

const getPageHref = (pageNumber: number) => `${firstUrl}${pageNumber === 1 ? '' : pageNumber}`;

const getVisiblePages = (totalPages: number, current: number) => {
  if (totalPages <= 7) return Array.from({ length: totalPages }, (_, index) => index + 1);

  if (current <= 4) {
    return [1, 2, 3, 4, 5, 'ellipsis', totalPages];
  }

  if (current >= totalPages - 3) {
    return [1, 'ellipsis', totalPages - 4, totalPages - 3, totalPages - 2, totalPages - 1, totalPages];
  }

  return [1, 'ellipsis', current - 1, current, current + 1, 'ellipsis', totalPages];
};

const visiblePages = getVisiblePages(length, currentPage);
---

<nav class='nd-pagination' aria-label='Pagination'>
  <ol class='nd-pagination-list'>
    {
      prevUrl ? (
        <li>
          <a href={prevUrl} class='nd-page-btn nd-page-arrow' aria-label='Previous page'>
            <PrevIcon />
          </a>
        </li>
      ) : null
    }
    {
      visiblePages.map((item) => (
        <li>
          {item === 'ellipsis' ? (
            <span class='nd-page-ellipsis'>…</span>
          ) : (
            <a
              href={getPageHref(item as number)}
              aria-current={currentPage === item ? 'page' : undefined}
              class={`nd-page-btn ${currentPage === item ? 'nd-page-active' : ''}`}
            >
              {item}
            </a>
          )}
        </li>
      ))
    }
    {
      nextUrl ? (
        <li>
          <a href={nextUrl} class='nd-page-btn nd-page-arrow' aria-label='Next page'>
            <NextIcon />
          </a>
        </li>
      ) : null
    }
  </ol>
</nav>

<style>
  .nd-pagination {
    margin-top: 48px;
    display: flex;
    justify-content: center;
  }

  .nd-pagination-list {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 6px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nd-page-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding: 0 10px;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--nd-text-secondary);
    border: 1px solid var(--nd-border-visible);
    border-radius: 6px;
    transition: color 200ms ease, border-color 200ms ease, background 200ms ease;
  }

  .nd-page-btn:hover {
    color: var(--nd-text-display);
    border-color: var(--nd-text-disabled);
  }

  .nd-page-active {
    color: var(--nd-text-display);
    background: var(--nd-surface-raised);
    border-color: var(--nd-text-disabled);
  }

  .nd-page-arrow {
    color: var(--nd-text-secondary);
  }

  .nd-page-ellipsis {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    color: var(--nd-text-disabled);
  }
</style>

---
import Header from '@components/Header.astro';
import Hero from '@components/Hero.astro';
import FeaturedVideos from '@components/FeaturedVideos.astro';
import Footer from '@components/Footer.astro';
import config from '@config/config.json';
import { locales, type Locale, stripLocaleFromPath, withLocalePath } from '@i18n/config';

import '@styles/global.css';

import { ViewTransitions } from 'astro:transitions';

export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  blogpost?: boolean;
  locale?: Locale;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleSection?: string;
  articleTags?: string[];
}

const {
  title,
  meta_title,
  description,
  image,
  noindex,
  blogpost,
  canonical,
  locale = 'es',
  articlePublishedTime,
  articleModifiedTime,
  articleSection,
  articleTags
} = Astro.props as Props;

const pageTitle = meta_title || title || config.site.title;
const pageDescription = description || config.metadata.meta_description;
const ogImage = image || 'https://s3.us-east-1.amazonaws.com/gndx.dev/gndx_og.jpg';
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, config.site.base_url).toString();
const canonicalUrl = canonical || new URL(Astro.url.pathname, config.site.base_url).toString();
const pathWithoutLocale = stripLocaleFromPath(Astro.url.pathname);
const isDev = import.meta.env.DEV;
const robots = noindex
  ? 'noindex,nofollow'
  : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1';

const ogLocaleMap: Record<Locale, string> = {
  es: 'es_ES',
  en: 'en_US',
  pt: 'pt_BR'
};
const ogLocale = ogLocaleMap[locale];
const alternateOgLocales = locales.filter((lang) => lang !== locale).map((lang) => ogLocaleMap[lang]);
const ogType = blogpost ? 'article' : 'website';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset='utf-8' />
    <link rel='shortcut icon' href={config.site.favicon} />
    <meta name='theme-name' content='bookworm-light-astro' />
    <meta name='msapplication-TileColor' content='#000000' />
    <meta name='theme-color' media='(prefers-color-scheme: light)' content='#fff' />
    <meta name='generator' content={Astro.generator} />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    {blogpost && <link rel='preconnect' href='https://fonts.googleapis.com' />}
    {blogpost && <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />}
    {blogpost && (
      <link
        href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap'
        rel='stylesheet'
      />
    )}

    <title>{pageTitle}</title>
    <meta name='title' content={pageTitle} />
    <meta name='description' content={pageDescription} />
    <meta name='author' content={config.metadata.meta_author} />
    <meta name='robots' content={robots} />

    <link rel='canonical' href={canonicalUrl} item-prop='url' />
    {
      locales.map((lang) => (
        <link
          rel='alternate'
          hreflang={lang}
          href={new URL(withLocalePath(lang, pathWithoutLocale), config.site.base_url).toString()}
        />
      ))
    }
    <link
      rel='alternate'
      hreflang='x-default'
      href={new URL(withLocalePath('es', pathWithoutLocale), config.site.base_url).toString()}
    />

    <meta property='og:title' content={pageTitle} />
    <meta property='og:description' content={pageDescription} />
    <meta property='og:type' content={ogType} />
    <meta property='og:url' content={canonicalUrl} />
    <meta property='og:image' content={ogImageUrl} />
    <meta property='og:site_name' content={config.site.title} />
    <meta property='og:locale' content={ogLocale} />
    {alternateOgLocales.map((ogAltLocale) => <meta property='og:locale:alternate' content={ogAltLocale} />)}

    {blogpost && articlePublishedTime && (
      <meta property='article:published_time' content={articlePublishedTime} />
    )}
    {blogpost && articleModifiedTime && <meta property='article:modified_time' content={articleModifiedTime} />}
    {blogpost && articleSection && <meta property='article:section' content={articleSection} />}
    {blogpost && articleTags?.map((tag) => <meta property='article:tag' content={tag} />)}

    <meta name='twitter:title' content={pageTitle} />
    <meta name='twitter:description' content={pageDescription} />
    <meta name='twitter:image' content={ogImageUrl} />
    <meta name='twitter:card' content='summary_large_image' />

    {
      isDev && (
        <script is:inline>
          if ('serviceWorker' in navigator) {
            navigator.serviceWorker.getRegistrations().then((registrations) => {
              registrations.forEach((registration) => registration.unregister());
            });
          }
        </script>
      )
    }
    {!isDev && <script is:inline src='/registerSW.js'></script>}
    {!isDev && <link rel='manifest' href='/manifest.webmanifest' />}
    <ViewTransitions />
    <script
      defer
      src='https://us.umami.is/script.js'
      data-website-id='db3f0d8a-7fde-495b-9d0f-d45267e61cff'></script>
  </head>
  <body>
    {!blogpost && (
      <div class='bg-green-600 px-4 py-4 text-white'>
        <p class='text-center text-md font-medium text-green-100'>
          <a href='https://mentor.gndx.dev/' class='font-bold ml-1'>
            🚀 ¿Cómo Aprovechar al Máximo una Mentoría?
          </a>
        </p>
      </div>
    )}
    <Header locale={locale} />
    {!blogpost && <Hero />}
    <main class='mx-auto max-w-screen-lg px-4 py-8 sm:px-6 sm:py-12 lg:px-8'>
      <slot />
    </main>
    {!blogpost && <FeaturedVideos />}
    <Footer />
    <script>
      // This is a hack to get vite-plugin-pwa to generate a sw.js file.
      // Do not remove this script tag.
    </script>
  </body>
</html>

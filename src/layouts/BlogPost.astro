---
import Base from '@layouts/Base.astro';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '@components/FormattedDate.astro';
import CalendarIcon from '@icons/CalendarIcon.astro';
import CategoryIcon from '@icons/CategoryIcon.astro';
import GiscusComments from '@components/GiscusComments.astro';
import { Image } from 'astro:assets';
import config from '@config/config.json';
import { slugify } from '@utils/slug';
import { type Locale, withLocalePath } from '@i18n/config';

interface Props extends CollectionEntry<'blogEs'>['data'] {
  locale?: Locale;
  ogImage?: string;
}

const { title, description, pubDate, updatedDate, heroImage, categories, tags, ogImage, locale = 'es' } =
  Astro.props as Props;
const dateLocaleMap: Record<Locale, string> = {
  es: 'es-ES',
  en: 'en-US',
  pt: 'pt-BR'
};
const normalizedPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const articleUrl = new URL(normalizedPath, config.site.base_url).toString();
const articleImage = ogImage || heroImage;
const imageUrl = articleImage
  ? articleImage.startsWith('http')
    ? articleImage
    : new URL(articleImage, config.site.base_url).toString()
  : undefined;
const publisherLogo = config.site.logo.startsWith('http')
  ? config.site.logo
  : new URL(config.site.logo, config.site.base_url).toString();

const blogPostingLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate || pubDate).toISOString(),
  inLanguage: locale,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': articleUrl
  },
  ...(imageUrl ? { image: [imageUrl] } : {}),
  author: [
    {
      '@type': 'Person',
      name: config.author.name
    }
  ],
  publisher: {
    '@type': 'Organization',
    name: config.site.title,
    logo: {
      '@type': 'ImageObject',
      url: publisherLogo
    }
  },
  ...(categories?.length ? { articleSection: categories[0] } : {}),
  ...(tags?.length ? { keywords: tags.join(', ') } : {})
};
---

<Base
  meta_title={title}
  description={description}
  image={ogImage || heroImage}
  blogpost
  locale={locale}
  articlePublishedTime={pubDate.toISOString()}
  articleModifiedTime={(updatedDate || pubDate).toISOString()}
  articleSection={categories?.[0]}
  articleTags={tags}
>
  <article class='article-shell'>
    <header class='bp-header'>
      <h1 class='bp-title'>{title}</h1>
      <div class='bp-meta'>
        <div class='flex flex-wrap items-center gap-1.5'>
          <figure>
            <Image
              alt={config.author.name}
              class='bp-avatar'
              width={50}
              height={50}
              src={config.author.avatar}
              decoding='async'
              loading='lazy'
            />
          </figure>
          <span>{config.author.name}</span>
        </div>
        <span class='bp-meta-dot'>·</span>
        <div class='flex flex-wrap items-center gap-1.5'>
          <CalendarIcon />
          <FormattedDate date={pubDate} locale={dateLocaleMap[locale]} />
        </div>
        {
          categories?.slice(0, 1).map((category) => (
            <>
              <span class='bp-meta-dot'>·</span>
              <div class='flex flex-wrap items-center gap-1.5'>
                <CategoryIcon />
                <a
                  href={withLocalePath(locale, `/categories/${slugify(category)}`)}
                  class='bp-category-link capitalize'
                >
                  {category}
                </a>
              </div>
            </>
          ))
        }
      </div>
    </header>
    <script type='application/ld+json' set:html={JSON.stringify(blogPostingLd)} />
    <div class='article-content prose mx-auto'>
      <slot />
    </div>
    <script is:inline>
      const COPY_LABEL = 'Copiar';
      const COPIED_LABEL = 'Copiado';
      const CODE_BLOCK_SELECTOR = '.article-content pre.astro-code, .article-content pre.gndx';

      const inferLanguage = (block) => {
        if (block.dataset.language) return;
        const code = block.querySelector('code');
        if (!code) return;
        const languageClass = Array.from(code.classList).find((value) => value.startsWith('language-'));
        const language = languageClass ? languageClass.replace('language-', '') : 'code';
        block.dataset.language = language.toUpperCase();
      };

      const getCodeText = (block) => {
        const lines = block.querySelectorAll('code > span.line');
        if (lines.length > 0) {
          return Array.from(lines)
            .map((line) => line.textContent ?? '')
            .join('\n')
            .replace(/\n+$/g, '');
        }
        return block.querySelector('code')?.textContent?.trim() || '';
      };

      const bindCopyBehavior = (block, button, check) => {
        if (button.dataset.bound === 'true') return;
        button.dataset.bound = 'true';
        check.textContent = COPIED_LABEL;

        button.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(getCodeText(block));
            check.classList.add('is-visible');
            button.classList.add('is-hidden');
            setTimeout(() => {
              check.classList.remove('is-visible');
              button.classList.remove('is-hidden');
            }, 1700);
          } catch {
            check.classList.remove('is-visible');
            button.classList.remove('is-hidden');
          }
        });
      };

      const ensureLanguageChip = (block) => {
        let chip = block.querySelector('.code-language-chip');
        if (!chip) {
          chip = document.createElement('span');
          chip.className = 'code-language-chip';
          chip.setAttribute('aria-hidden', 'true');
          block.append(chip);
        }
        chip.textContent = block.dataset.language || 'CODE';
      };

      const ensureCopyControls = (block) => {
        let button = block.querySelector('.copy-button');
        if (!button) {
          button = document.createElement('button');
          block.append(button);
        }
        button.type = 'button';
        button.className = 'copy-button';
        button.setAttribute('aria-label', COPY_LABEL);
        button.textContent = COPY_LABEL;

        let check = block.querySelector('.check-span');
        if (!check) {
          check = document.createElement('span');
          block.append(check);
        }
        check.className = 'check-span';
        check.setAttribute('aria-hidden', 'true');
        check.textContent = COPIED_LABEL;

        bindCopyBehavior(block, button, check);
      };

      const normalizeLineDensity = (block) => {
        block.querySelectorAll('code > span.line').forEach((line) => {
          const isBlank = (line.textContent || '').trim().length === 0;
          line.classList.toggle('is-blank-line', isBlank);
        });
      };

      const initCodeBlocks = () => {
        document.querySelectorAll(CODE_BLOCK_SELECTOR).forEach((block) => {
          inferLanguage(block);
          normalizeLineDensity(block);
          ensureLanguageChip(block);
          ensureCopyControls(block);
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCodeBlocks, { once: true });
      } else {
        initCodeBlocks();
      }
      document.addEventListener('astro:page-load', initCodeBlocks);
    </script>
    <div class='bp-tags'>
      {
        tags?.map((tag) => (
          <a
            href={withLocalePath(locale, `/tags/${slugify(tag)}`)}
            class='bp-tag'
          >
            #{tag}
          </a>
        ))
      }
    </div>
    <GiscusComments locale={locale} />
  </article>
</Base>

<style>
  .bp-header {
    margin-bottom: 40px;
    text-align: center;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--nd-border);
  }

  .bp-title {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--nd-text-display);
    text-wrap: balance;
    margin: 0 0 20px 0;
  }

  .bp-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 8px 16px;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--nd-text-secondary);
  }

  .bp-meta-dot {
    color: var(--nd-border-visible);
  }

  .bp-avatar {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 1px solid var(--nd-border-visible);
  }

  .bp-category-link {
    color: var(--nd-text-secondary);
    transition: color 200ms ease;
  }

  .bp-category-link:hover {
    color: var(--nd-text-display);
  }

  .bp-tags {
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid var(--nd-border);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
  }

  .bp-tag {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--nd-text-secondary);
    border: 1px solid var(--nd-border-visible);
    padding: 4px 14px;
    border-radius: 999px;
    transition: color 200ms ease, border-color 200ms ease;
  }

  .bp-tag:hover {
    color: var(--nd-text-display);
    border-color: var(--nd-text-disabled);
  }
</style>

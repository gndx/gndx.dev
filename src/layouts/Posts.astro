---
import FormattedDate from '@components/FormattedDate.astro';
import { type Locale, withLocalePath } from '@i18n/config';
import { heroPatterns } from '@utils/heroPatterns';

interface Props {
  posts: PostType[];
  locale?: Locale;
}

const { posts, locale = 'es' } = Astro.props as Props;

const dateLocaleMap: Record<Locale, string> = {
  es: 'es-ES',
  en: 'en-US',
  pt: 'pt-BR'
};

const labelsByLocale: Record<Locale, { author: string; tags: string; untagged: string; uncategorized: string }> = {
  es: { author: 'Autor', tags: 'Tags', untagged: '#sin-tag', uncategorized: 'Sin categoria' },
  en: { author: 'Author', tags: 'Tags', untagged: '#untagged', uncategorized: 'Uncategorized' },
  pt: { author: 'Autor', tags: 'Tags', untagged: '#sem-tag', uncategorized: 'Sem categoria' }
};

const labels = labelsByLocale[locale];

const getPostSlug = (post: PostType) => post.slug || post.id?.replace(/\.(md|mdx)$/i, '') || '';

const bentoVariants = [
  'md:col-span-3',
  'md:col-span-3',
  'md:col-span-3',
  'md:col-span-3',
  'md:col-span-2',
  'md:col-span-2',
  'md:col-span-2',
  'md:col-span-3',
  'md:col-span-3'
] as const;

const getBentoVariant = (index: number) => bentoVariants[index % bentoVariants.length];

const patternForegroundPalette = [
  '#0f172a',
  '#1f2937',
  '#334155',
  '#3f3f46',
  '#0b3b2e',
  '#4a3419',
  '#312e81',
  '#3b0764'
];

const cardSurfacePalette = [
  '#f9fafb',
  '#f8fafc',
  '#fdf4ff',
  '#eff6ff',
  '#f0fdf4',
  '#fef3c7',
  '#fef2f2',
  '#ecfeff'
];

const hashString = (value: string) => {
  let hash = 0;
  for (let index = 0; index < value.length; index += 1) {
    hash = (hash << 5) - hash + value.charCodeAt(index);
    hash |= 0;
  }
  return Math.abs(hash);
};

const withOpacity = (hex: string, opacity: number) => {
  const normalized = hex.replace('#', '');
  const withFullLength =
    normalized.length === 3
      ? normalized
          .split('')
          .map((part) => `${part}${part}`)
          .join('')
      : normalized;
  const r = Number.parseInt(withFullLength.slice(0, 2), 16);
  const g = Number.parseInt(withFullLength.slice(2, 4), 16);
  const b = Number.parseInt(withFullLength.slice(4, 6), 16);
  return `rgba(${r}, ${g}, ${b}, ${opacity})`;
};

const toPatternDataUri = (svg: string, color: string) => {
  const coloredSvg = svg.replace(/#000/g, color).replace(/\n/g, '').replace(/\s{2,}/g, ' ');
  return `url("data:image/svg+xml,${encodeURIComponent(coloredSvg)}")`;
};

const getPatternStyle = (post: PostType, index: number) => {
  const seed = hashString(`${post.id}-${post.data.title}-${index}`);
  const pattern = heroPatterns[seed % heroPatterns.length];
  const patternColorBase = patternForegroundPalette[Math.floor(seed / 3) % patternForegroundPalette.length];
  const surfaceColor = cardSurfacePalette[Math.floor(seed / 7) % cardSurfacePalette.length];
  const patternColor = withOpacity(patternColorBase, 0.4);

  return {
    surfaceColor,
    patternImage: toPatternDataUri(pattern.svg, patternColor)
  };
};

type PostType = {
  id: string;
  slug?: string;
  body: string;
  collection: string;
  data: {
    title: string;
    description: string;
    heroImage?: string;
    pubDate: Date;
    categories: string[];
    tags: string[];
    authors: string[];
  };
};
---

<div class="mx-auto grid grid-cols-1 gap-5 md:grid-flow-row-dense md:grid-cols-6 md:auto-rows-[minmax(150px,auto)]">
  {
    posts?.slice(0, 9).map((post: PostType, index: number) => {
      const { surfaceColor, patternImage } = getPatternStyle(post, index);
      const authors = post.data.authors?.filter(Boolean).join(', ') || 'gndx';
      const tags = post.data.tags?.slice(0, 2) || [];
      const postSlug = getPostSlug(post);
      const primaryCategory = post.data.categories?.[0] || labels.uncategorized;

      return (
        <article class={`bento-card group relative flex h-full flex-col overflow-hidden rounded-3xl border border-zinc-200/80 bg-white/95 ${getBentoVariant(index)}`}>
          <a href={withLocalePath(locale, `/blog/${postSlug}`)} class="absolute inset-0 z-10" aria-label={post.data.title} />

          <div class={`relative overflow-hidden border-b border-zinc-200/80 ${index === 0 ? 'h-44 md:h-52' : 'h-36'}`}>
            <div class="bento-pattern-layer absolute inset-0" style={`background-color:${surfaceColor}; background-image:${patternImage};`} />
            <div class="absolute inset-0 bg-gradient-to-br from-white/55 via-white/10 to-zinc-900/15" />
            <span class="absolute left-4 top-4 inline-flex rounded-full border border-white/70 bg-white/85 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.08em] text-zinc-700">
              {primaryCategory}
            </span>
          </div>

          <div class="relative z-20 flex flex-1 flex-col gap-3 p-5">
            <div class="flex flex-wrap items-center gap-2 text-xs text-zinc-500">
              <FormattedDate date={post.data.pubDate} locale={dateLocaleMap[locale]} />
              <span class="text-zinc-300">•</span>
              <span class="font-medium text-zinc-700">{labels.author}: {authors}</span>
            </div>

            <h2 class="text-xl font-semibold leading-tight text-zinc-900">
              <a href={withLocalePath(locale, `/blog/${postSlug}`)} class="relative z-20 transition-colors duration-200 group-hover:text-zinc-600">
                {post.data.title}
              </a>
            </h2>

            <p class="line-clamp-3 text-sm leading-relaxed text-zinc-600">{post.data.description}</p>

            <div class="flex flex-wrap items-center gap-2 pt-1">
              <span class="text-[11px] uppercase tracking-[0.08em] text-zinc-400">{labels.tags}</span>
              {
                tags.length > 0 ? (
                  tags.map((tag) => (
                    <span class="rounded-full border border-zinc-200 bg-zinc-50 px-2.5 py-1 text-[11px] font-medium text-zinc-600">
                      #{tag}
                    </span>
                  ))
                ) : (
                  <span class="rounded-full border border-zinc-200 bg-zinc-50 px-2.5 py-1 text-[11px] font-medium text-zinc-600">
                    {labels.untagged}
                  </span>
                )
              }
            </div>
          </div>
        </article>
      );
    })
  }
</div>

<style>
  .bento-card {
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06), 0 10px 24px rgba(15, 23, 42, 0.05);
    transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
  }

  .bento-card:hover {
    transform: translateY(-4px);
    border-color: rgba(113, 113, 122, 0.35);
    box-shadow: 0 14px 36px rgba(15, 23, 42, 0.12);
  }

  .bento-pattern-layer {
    background-repeat: repeat;
    animation: bentoPatternShift 46s linear infinite;
  }

  .bento-card:hover .bento-pattern-layer {
    animation-duration: 39s;
  }

  @keyframes bentoPatternShift {
    from {
      background-position: 0 0;
    }

    to {
      background-position: 42px 30px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bento-card {
      transition: none;
    }

    .bento-card:hover {
      transform: none;
    }

    .bento-pattern-layer,
    .bento-card:hover .bento-pattern-layer {
      animation: none;
    }
  }
</style>

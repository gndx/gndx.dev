---
import FormattedDate from '@components/FormattedDate.astro';
import { type Locale, withLocalePath } from '@i18n/config';
import { heroPatterns } from '@utils/heroPatterns';

interface Props {
  posts: PostType[];
  locale?: Locale;
}

const { posts, locale = 'es' } = Astro.props as Props;

const dateLocaleMap: Record<Locale, string> = {
  es: 'es-ES',
  en: 'en-US',
  pt: 'pt-BR'
};

const labelsByLocale: Record<Locale, { author: string; tags: string; untagged: string; uncategorized: string }> = {
  es: { author: 'Autor', tags: 'Tags', untagged: '#sin-tag', uncategorized: 'Sin categoria' },
  en: { author: 'Author', tags: 'Tags', untagged: '#untagged', uncategorized: 'Uncategorized' },
  pt: { author: 'Autor', tags: 'Tags', untagged: '#sem-tag', uncategorized: 'Sem categoria' }
};

const labels = labelsByLocale[locale];

const getPostSlug = (post: PostType) => post.slug || post.id?.replace(/\.(md|mdx)$/i, '') || '';

const bentoVariants = [
  'md:col-span-3',
  'md:col-span-3',
  'md:col-span-3',
  'md:col-span-3',
  'md:col-span-2',
  'md:col-span-2',
  'md:col-span-2',
  'md:col-span-3',
  'md:col-span-3'
] as const;

const getBentoVariant = (index: number) => bentoVariants[index % bentoVariants.length];

/* Dark surfaces + colored patterns — each card has a distinct tint */
const patternForegroundPalette = [
  '#d71921', // nothing red
  '#5b9bf6', // interactive blue
  '#4a9e5c', // success green
  '#d4a843', // warning amber
  '#8b5cf6', // violet
  '#22d3ee', // cyan
  '#f97316', // orange
  '#e879f9', // fuchsia
];

const cardSurfacePalette = [
  '#0d0a0a', // warm dark (red tint)
  '#090d12', // cool dark (blue tint)
  '#090d0a', // green dark
  '#0d0c08', // amber dark
  '#0b090f', // violet dark
  '#080d0e', // cyan dark
  '#0e0b07', // orange dark
  '#0e0810', // fuchsia dark
];

const hashString = (value: string) => {
  let hash = 0;
  for (let index = 0; index < value.length; index += 1) {
    hash = (hash << 5) - hash + value.charCodeAt(index);
    hash |= 0;
  }
  return Math.abs(hash);
};

const withOpacity = (hex: string, opacity: number) => {
  const normalized = hex.replace('#', '');
  const withFullLength =
    normalized.length === 3
      ? normalized
          .split('')
          .map((part) => `${part}${part}`)
          .join('')
      : normalized;
  const r = Number.parseInt(withFullLength.slice(0, 2), 16);
  const g = Number.parseInt(withFullLength.slice(2, 4), 16);
  const b = Number.parseInt(withFullLength.slice(4, 6), 16);
  return `rgba(${r}, ${g}, ${b}, ${opacity})`;
};

const toPatternDataUri = (svg: string, color: string) => {
  const coloredSvg = svg.replace(/#000/g, color).replace(/\n/g, '').replace(/\s{2,}/g, ' ');
  return `url("data:image/svg+xml,${encodeURIComponent(coloredSvg)}")`;
};

const getPatternStyle = (post: PostType, index: number) => {
  const seed = hashString(`${post.id}-${post.data.title}-${index}`);
  const pattern = heroPatterns[seed % heroPatterns.length];
  const patternColorBase = patternForegroundPalette[Math.floor(seed / 3) % patternForegroundPalette.length];
  const surfaceColor = cardSurfacePalette[Math.floor(seed / 7) % cardSurfacePalette.length];
  const patternColor = withOpacity(patternColorBase, 0.22);

  return {
    surfaceColor,
    patternImage: toPatternDataUri(pattern.svg, patternColor)
  };
};

type PostType = {
  id: string;
  slug?: string;
  body: string;
  collection: string;
  data: {
    title: string;
    description: string;
    heroImage?: string;
    pubDate: Date;
    categories: string[];
    tags: string[];
    authors: string[];
  };
};
---

<div class="mx-auto grid grid-cols-1 gap-4 md:grid-flow-row-dense md:grid-cols-6 md:auto-rows-[minmax(150px,auto)]">
  {
    posts?.slice(0, 9).map((post: PostType, index: number) => {
      const { surfaceColor, patternImage } = getPatternStyle(post, index);
      const authors = post.data.authors?.filter(Boolean).join(', ') || 'gndx';
      const tags = post.data.tags?.slice(0, 2) || [];
      const postSlug = getPostSlug(post);
      const primaryCategory = post.data.categories?.[0] || labels.uncategorized;

      return (
        <article class={`nd-card group relative flex h-full flex-col overflow-hidden ${getBentoVariant(index)}`}>
          <a href={withLocalePath(locale, `/blog/${postSlug}`)} class="absolute inset-0 z-10" aria-label={post.data.title} />

          {/* Pattern image area */}
          <div class={`nd-card-pattern relative overflow-hidden ${index === 0 ? 'h-44 md:h-52' : 'h-36'}`}
               style={`background-color:${surfaceColor}; background-image:${patternImage};`}>
            <div class="nd-pattern-overlay absolute inset-0" style="background: linear-gradient(160deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.15) 100%);" />
            <span class="nd-category-badge absolute left-4 top-4">
              {primaryCategory}
            </span>
          </div>

          {/* Card body */}
          <div class="relative z-20 flex flex-1 flex-col gap-2.5 p-5">
            <div class="nd-meta flex flex-wrap items-center gap-2">
              <FormattedDate date={post.data.pubDate} locale={dateLocaleMap[locale]} />
              <span class="nd-meta-dot">·</span>
              <span>{authors}</span>
            </div>

            <h2 class="nd-card-title">
              <a href={withLocalePath(locale, `/blog/${postSlug}`)} class="relative z-20">
                {post.data.title}
              </a>
            </h2>

            <p class="nd-card-desc line-clamp-3">{post.data.description}</p>

            <div class="flex flex-wrap items-center gap-2 pt-1">
              <span class="nd-tags-label">{labels.tags}</span>
              {
                tags.length > 0 ? (
                  tags.map((tag) => (
                    <span class="nd-tag">#{tag}</span>
                  ))
                ) : (
                  <span class="nd-tag">{labels.untagged}</span>
                )
              }
            </div>
          </div>
        </article>
      );
    })
  }
</div>

<style>
  .nd-card {
    background: var(--nd-surface);
    border: 1px solid var(--nd-border);
    border-radius: 12px;
    transition: border-color 250ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .nd-card:hover {
    border-color: var(--nd-border-visible);
  }

  .nd-card-pattern {
    border-bottom: 1px solid var(--nd-border);
    background-repeat: repeat;
    animation: patternShift 50s linear infinite;
  }

  .nd-card:hover .nd-card-pattern {
    animation-duration: 40s;
  }

  @keyframes patternShift {
    from { background-position: 0 0; }
    to   { background-position: 42px 30px; }
  }

  .nd-category-badge {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--nd-text-secondary);
    border: 1px solid var(--nd-border-visible);
    padding: 4px 10px;
    border-radius: 999px;
    background: transparent;
  }

  .nd-meta {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--nd-text-secondary);
  }

  .nd-meta-dot {
    color: var(--nd-border-visible);
  }

  .nd-card-title {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--nd-text-display);
    transition: color 200ms ease;
  }

  .nd-card:hover .nd-card-title {
    color: var(--nd-text-primary);
  }

  .nd-card-desc {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--nd-text-secondary);
  }

  .nd-tags-label {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--nd-text-secondary);
  }

  .nd-tag {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--nd-text-secondary);
    border: 1px solid var(--nd-border-visible);
    padding: 3px 10px;
    border-radius: 999px;
  }

  /* Light mode: override dark tinted surfaces to light surface */
  :root[data-theme='light'] .nd-card-pattern {
    background-color: var(--nd-surface-raised) !important;
  }

  :root[data-theme='light'] .nd-pattern-overlay {
    background: linear-gradient(160deg, rgba(0,0,0,0.06) 0%, rgba(0,0,0,0.02) 100%) !important;
  }

  @media (prefers-color-scheme: light) {
    :root:not([data-theme='dark']) .nd-card-pattern {
      background-color: var(--nd-surface-raised) !important;
    }

    :root:not([data-theme='dark']) .nd-pattern-overlay {
      background: linear-gradient(160deg, rgba(0,0,0,0.06) 0%, rgba(0,0,0,0.02) 100%) !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nd-card { transition: none; }
    .nd-card-pattern,
    .nd-card:hover .nd-card-pattern { animation: none; }
  }
</style>
